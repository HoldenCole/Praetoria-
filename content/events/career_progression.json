      ],
      "choices": [
        {
          "id": "govern_justly",
          "requires": [
            {
              "type": "trait",
              "role": "self",
              "trait": "Just",
              "kind": "nature",
              "present": true
            }
          ],
          "effects": [
            {
              "type": "advanceCareer",
              "role": "self"
            },
            {
              "type": "adjustCounter",
              "key": "goodwill",
              "delta": 3
            },
            {
              "type": "adjustResource",
              "resource": "credits",
              "delta": -2
            },
            {
              "type": "log",
              "text": "{self.name} took the governor's seat and governed as though the people on the ledger had faces, because they did. The province prospered slower and steadier than a harder hand would have driven it — and stayed loyal through the lean year that broke {self.name}'s harsher neighbors. Justice is a slow economy. It pays in crises."
            }
          ]
        },
        {
          "id": "govern_efficiently",
          "effects": [
            {
              "type": "advanceCareer",
              "role": "self"
            },
            {
              "type": "adjustResource",
              "resource": "credits",
              "delta": 5
            },
            {
              "type": "adjustCounter",
              "key": "unrest",
              "delta": 1
            },
            {
              "type": "log",
              "text": "{self.name} took the seat and ran the province like a well-tuned engine — every inefficiency trimmed, every yield maximized, the numbers immaculate. The treasury swelled. The people became, in {self.name}'s ledgers, a number that produces and occasionally complains. Both facts are true at once, and a governor must choose which to forget."
            }
          ]
        },
        {
          "id": "govern_for_profit",
          "requires": [
            {
              "type": "trait",
              "role": "self",
              "trait": "Greedy",
              "kind": "aptitude",
              "present": true
            }
          ],
          "effects": [
            {
              "type": "advanceCareer",
              "role": "self"
            },
            {
              "type": "adjustResource",
              "resource": "credits",
              "delta": 9
            },
            {
              "type": "adjustCounter",
              "key": "corruption",
              "delta": 2
            },
            {
              "type": "adjustCounter",
              "key": "unrest",
              "delta": 2
            },
            {
              "type": "log",
              "text": "{self.name} treated the governorship as the opportunity everyone privately knows it to be, and the province paid {self.name} as much as it paid the throne. A fortune made. A reckoning postponed. Every governor who has done this has believed they would be the one to leave before the bill arrived. Most were wrong."
            }
          ]
        }
      ]
    },
